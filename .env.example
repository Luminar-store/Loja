# =========================================================================
# LUMINAR JOIAS — TEMPLATE DE VARIÁVEIS DE AMBIENTE (.env.example)
# Copie este arquivo para .env.local em ambiente de desenvolvimento local
# Para produção, configure estas chaves no painel da Vercel (Environment Variables)
# =========================================================================

# -------------------------------------------------------------------------
# 1. CONEXÃO COM O SUPABASE (Obrigatório - Storefront e Servidor)
# -------------------------------------------------------------------------
# URL pública do projeto no Supabase (ex: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Anon Key do Supabase (Chave pública anônima)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key do Supabase (Chave secreta privada)
# ATENÇÃO: NUNCA exponha esta chave publicamente. Ela é usada exclusivamente no servidor
# para fazer bypass em RLS e gerenciar autenticação admin.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------------------------------------------------------
# 2. CONFIGURAÇÕES DA LOJA E LOGÍSTICA SUPERFRETE (Obrigatório - Servidor/Client)
# -------------------------------------------------------------------------
# CEP de Origem da Loja física/oficina para cálculo logística de frete (apenas números)
# Padrão de fallback se ausente: '40000000'
NEXT_PUBLIC_STORE_ZIP_CODE=40000000

# Token da API de Produção ou Sandbox da SuperFrete
# Caso esteja ausente ou utilize valor 'dummy', o sistema ativa automaticamente o frete de fallback
# estável (PAC sob Encomenda por R$ 29,90 e SEDEX Express por R$ 49,90)
SUPERFRETE_TOKEN=your-superfrete-api-token

# -------------------------------------------------------------------------
# 3. INFINITEPAY - GATEWAY DE PAGAMENTO (Obrigatório - Servidor)
# -------------------------------------------------------------------------
# API Key secreta da InfinitePay (Sandbox ou Produção)
# Caso esteja ausente ou utilize valor 'dummy', o checkout da loja gera links de simulação estáveis
INFINITEPAY_API_KEY=your-infinitepay-api-key

# Segredo de validação de Webhooks da InfinitePay (SHA256 HMAC)
# Necessário para verificar criptograficamente a autenticidade dos callbacks de pagamento aprovado
INFINITEPAY_WEBHOOK_SECRET=your-infinitepay-webhook-secret

# -------------------------------------------------------------------------
# 4. CONFIGURAÇÕES PÚBLICAS DO SITE (Obrigatório - Links de Pagamento e Redirects)
# -------------------------------------------------------------------------
# URL base pública da loja instalada (utilizada para callbacks e links de redirecionamento do checkout)
# Local: http://localhost:3000
# Produção: https://sua-loja.vercel.app ou seu domínio próprio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Número oficial de WhatsApp Concierge da grife (com código de país e DDD, sem espaços ou símbolos)
# Utilizado para o botão Concierge reativo e recuperação de carrinho
NEXT_PUBLIC_WHATSAPP_NUMBER=5575988313060

# -------------------------------------------------------------------------
# 5. SEGURANÇA E CACHE (Opcional)
# -------------------------------------------------------------------------
# Chave secreta de autenticação para revalidação manual de cache estático via API
REVALIDATE_SECRET=your-custom-revalidate-token-secret

# -------------------------------------------------------------------------
# 6. SENTRY - MONITORAMENTO DE ERROS (Opcional - Apenas Produção)
# -------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# DISABLE_SENTRY=true
